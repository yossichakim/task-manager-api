    "username": "yossi",
    "password": "123456"
}

### Get all tasks
GET http://127.0.0.1:5000/tasks
Authorization: Bearer {{access_token}}

### Create a task for the logged-in user
POST http://127.0.0.1:5000/tasks
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
    "title": "Learn task ownership",
    "description": "Connect tasks to users",
    "category": "study"
}

### Get current user's tasks
GET http://127.0.0.1:5000/tasks
Authorization: Bearer {{access_token}}

### Register second user
POST http://127.0.0.1:5000/register
Content-Type: application/json

{
    "username": "david",
    "password": "123456"
}

### Login as second user
# @name loginDavid
POST http://127.0.0.1:5000/login
Content-Type: application/json

{
    "username": "david",
    "password": "123456"
}

### Create task for David
POST http://127.0.0.1:5000/tasks
Content-Type: application/json
Authorization: Bearer {{loginDavid.response.body.access_token}}

{
    "title": "David task",
    "description": "This task belongs to David",
    "category": "personal"
}

### Get David's tasks
GET http://127.0.0.1:5000/tasks
Authorization: Bearer {{loginDavid.response.body.access_token}}

### Get Yossi's tasks
GET http://127.0.0.1:5000/tasks
Authorization: Bearer {{loginYossi.response.body.access_token}}

